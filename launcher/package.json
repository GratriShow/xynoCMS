{
  "name": "xyno-launcher-base",
  "version": "0.1.0",
  "private": true,
  "description": "Launcher Electron Xyno",
  "author": "XynoWeb",
  "main": "main.js",

  "scripts": {
    "dev": "electron .",
    "start": "electron .",

    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac --universal",
    "build:linux": "electron-builder --linux",

    "postinstall": "electron-builder install-app-deps",

    "build:update-zip": "node tools/makeUpdateZip.js",
    "build:obfuscate": "node tools/obfuscate.js",
    "start:obf": "npm run build:obfuscate && electron dist",

    "lint": "node -c main.js"
  },

  "build": {
    "appId": "com.xyno.launcher",
    "productName": "XynoLauncher",
    "artifactName": "${productName}.${ext}",

    "asar": true,

    "files": [
      "**/*",
      "!release/**",
      "!node_modules/.cache/**"
    ],

    "directories": {
      "output": "release"
    },

    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.games",
      "hardenedRuntime": false,
      "artifactName": "${productName}.${ext}"
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}.${ext}"
    },

    "nsis": {
      "artifactName": "${productName}.${ext}"
    },

    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}.${ext}"
    }
  },

  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^4.1.0"
  },

  "dependencies": {
    "minecraft-launcher-core": "^3.18.2",
    "prismarine-auth": "^3.1.1",
    "yazl": "^2.5.1",
    "yauzl": "^2.10.0"
  }
}
