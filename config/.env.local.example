# =============================================================================
# xynoCMS — variables d'environnement locales
# =============================================================================
# Copie ce fichier en `config/.env.local` et remplis les valeurs.
# Ce fichier NE DOIT PAS être committé (il est dans .gitignore côté CMS via
# `load_env_local()` — vérifie aussi que .env.local est bien ignoré par git).
#
# Le fichier est chargé automatiquement par config/bootstrap.php au démarrage
# de chaque requête PHP.
# =============================================================================


# --- Base URL publique du CMS (HTTPS obligatoire en prod) --------------------
# Utilisée par release_upload.php pour construire les URLs des fichiers.
# Laisse vide si ton serveur web expose déjà HTTP_HOST/REQUEST_SCHEME.
XYNO_PUBLIC_BASE_URL=https://ton-domaine.tld


# --- GitHub Actions (build des launchers) ------------------------------------
# Personal Access Token GitHub avec scope "repo" (classique) OU fine-grained
# avec permission "Actions: Read and write" sur le repo du launcher.
# Génère-le sur : https://github.com/settings/tokens
XYNO_GITHUB_TOKEN=

# Repo GitHub au format "owner/repo" (ex : GratriShow/xynoCMS).
XYNO_GITHUB_REPO=GratriShow/xynoCMS


# --- Tokens partagés CMS ↔ GitHub Actions ------------------------------------
# Chaîne aléatoire (≥32 chars) — à recopier à l'identique dans les Secrets
# du repo GitHub :
#   - BUILD_FETCH_TOKEN  (lit /api/build_config.php + POST /api/build_status.php)
#   - RELEASE_UPLOAD_TOKEN (upload des installers via /api/release_upload.php)
#
# Pour les générer : `openssl rand -hex 32`
XYNO_BUILD_FETCH_TOKEN=
XYNO_RELEASE_UPLOAD_TOKEN=

# Ancien nom de token, toujours utilisé par api/upload_build.php (legacy Mac).
# Tu peux le laisser vide si tu n'utilises plus upload_build.php.
XYNO_BUILD_TRIGGER_TOKEN=


# --- API v2 (auth signée launcher) -------------------------------------------
# Secret HS256 pour les JWT délivrés par /api/v2/session.php.
# Génère-le : `openssl rand -hex 32`
XYNO_JWT_SECRET=

# Si "1", lie chaque session v2 à l'IP cliente (plus strict mais casse en CGNAT).
XYNO_API_ENFORCE_IP=0


# --- Base de données (fallback si non défini dans config/database.php) ------
# Facultatif : si tes creds sont déjà dans config/database.php, laisse vide.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=xynocms
# DB_USER=xyno
# DB_PASS=
